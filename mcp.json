{
  "mcpServers": {
    "zai-mcp-server": {
      "command": "npx",
      "args": ["-y", "@z_ai/mcp-server"],
      "env": {
        "Z_AI_API_KEY": "${ZAI_API_KEY}",
        "Z_AI_MODE": "ZAI"
      },
      "directTools": true
    },
    "web-search-prime": {
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "auth": "bearer",
      "bearerTokenEnv": "ZAI_API_KEY",
      "directTools": true
    },
    "web-reader": {
      "url": "https://api.z.ai/api/mcp/web_reader/mcp",
      "auth": "bearer",
      "bearerTokenEnv": "ZAI_API_KEY",
      "directTools": true
    },
    "zread": {
      "url": "https://api.z.ai/api/mcp/zread/mcp",
      "auth": "bearer",
      "bearerTokenEnv": "ZAI_API_KEY",
      "directTools": true
    },
    "deepwiki": {
      "url": "https://mcp.deepwiki.com/mcp",
      "lifecycle": "lazy"
    },
    "svelte": {
      "url": "https://mcp.svelte.dev/mcp",
      "lifecycle": "lazy"
    }
  }
}
